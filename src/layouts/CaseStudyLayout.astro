---
import BaseLayout from './BaseLayout.astro'
import Header from '../components/global/Header.astro'
import Footer from '../components/global/Footer.astro'
import BaseSchema from '../components/schema/BaseSchema.astro'
import DualCTA from '../components/global/DualCTA.astro'

interface Stat {
  value: string
  label: string
}

interface RelatedAuthority {
  label: string
  href: string
  desc?: string
  color?: string
}

interface RelatedArticle {
  cluster: string
  clusterColor: string
  title: string
  excerpt: string
  readTime: number
  href: string
}

interface Props {
  title: string
  description: string
  cluster: string
  clusterColor: string
  h1: string
  standfirst: string
  metaLine: string
  heroImage: string
  stats: Stat[]
  slug: string
  publishDate: string
  keyTakeaways?: string[]
  procurementCallout?: string
  relatedAuthority: RelatedAuthority
  relatedArticles?: RelatedArticle[]
}

const {
  title,
  description,
  cluster,
  clusterColor,
  h1,
  standfirst,
  metaLine,
  heroImage,
  stats,
  slug,
  publishDate,
  keyTakeaways = [],
  procurementCallout,
  relatedAuthority,
  relatedArticles = [],
} = Astro.props

const siteUrl = 'https://cpclean.com.au'
const pageUrl = `${siteUrl}/case-studies/${slug}/`

const breadcrumbs = [
  { name: 'Home', url: `${siteUrl}/` },
  { name: 'Case Studies', url: `${siteUrl}/case-studies/` },
  { name: h1, url: pageUrl },
]

const serviceSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": `${pageUrl}#service`,
      "name": h1,
      "description": standfirst,
      "provider": { "@id": `${siteUrl}/#organization` },
      "serviceType": `${cluster} Cleaning`,
      "areaServed": { "@type": "Country", "name": "Australia" }
    },
    {
      "@type": "WebPage",
      "@id": `${pageUrl}#webpage`,
      "url": pageUrl,
      "name": title,
      "description": description,
      "isPartOf": { "@id": `${siteUrl}/#website` },
      "datePublished": publishDate,
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".cs-takeaways"]
      }
    }
  ]
}
---

<BaseLayout {title} {description}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <BaseSchema {breadcrumbs} />
  <Header />

  <main id="main-content">

    <!-- ══════════════════════════════ HERO ══════════════════════════════════ -->
    <section
      class="relative flex items-end overflow-hidden"
      style={`min-height: max(45vh, 400px); background-image: url('${heroImage}'); background-size: cover; background-position: center 35%;`}
      aria-label="Case study hero"
    >
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(to bottom, rgba(10,15,26,0.25) 0%, rgba(10,15,26,0.6) 40%, rgba(10,15,26,0.95) 100%)"
        aria-hidden="true"
      ></div>

      <div class="relative z-10 w-full max-w-screen-xl mx-auto px-4 sm:px-6 pt-28 pb-10">

        <!-- Eyebrow: cluster + CASE STUDY -->
        <div class="flex items-center gap-3 mb-3">
          <span
            class="inline-block w-2 h-2 rounded-full flex-shrink-0"
            style={`background: ${clusterColor}`}
            aria-hidden="true"
          ></span>
          <span
            class="text-xs font-bold tracking-widest uppercase"
            style={`color: ${clusterColor}`}
          >{cluster}</span>
          <span class="text-white/25 text-xs" aria-hidden="true">·</span>
          <span class="text-xs font-bold tracking-widest uppercase text-white/45">Case Study</span>
        </div>

        <!-- H1 -->
        <h1 class="font-display font-bold text-white text-balance max-w-3xl mb-4
                   text-2xl sm:text-3xl md:text-[2.5rem] leading-tight drop-shadow-lg">
          {h1}
        </h1>

        <!-- Standfirst -->
        <p class="text-base sm:text-lg text-white/70 max-w-2xl mb-5 leading-relaxed">
          {standfirst}
        </p>

        <!-- Meta line -->
        <p class="text-xs text-white/40 mb-6 tracking-wide font-medium">{metaLine}</p>

        <!-- Breadcrumb -->
        <nav aria-label="Breadcrumb">
          <ol class="flex flex-wrap items-center gap-1.5 text-xs text-white/30">
            <li><a href="/" class="hover:text-white/60 transition-colors">Home</a></li>
            <li aria-hidden="true">/</li>
            <li><a href="/case-studies/" class="hover:text-white/60 transition-colors">Case Studies</a></li>
            <li aria-hidden="true">/</li>
            <li class="text-white/50" aria-current="page">{h1}</li>
          </ol>
        </nav>
      </div>
    </section>

    <!-- ═══════════════════════════ PROOF BLOCK ══════════════════════════════ -->
    <div class="bg-white border-b border-slate-100 shadow-sm">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          {stats.map(s => (
            <div class="cs-stat-card">
              <div class="cs-stat-value">{s.value}</div>
              <div class="cs-stat-label">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- ════════════════════════ CONTENT AREA ════════════════════════════════ -->
    <div class="bg-white">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-12 lg:py-16">
        <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-16 xl:gap-20">

          <!-- ─── LEFT TOC SIDEBAR ─────────────────────────────────────────── -->
          <aside class="hidden lg:block" aria-label="Table of contents">
            <div class="sticky top-24 space-y-8">
              <div>
                <p class="auth-toc-label">On This Page</p>
                <nav id="toc" aria-label="Case study sections"></nav>
              </div>
              <div>
                <div class="flex items-center justify-between mb-2">
                  <p class="auth-toc-label">Progress</p>
                  <span id="progress-pct" class="text-[10px] text-teal font-mono font-bold">0%</span>
                </div>
                <div class="h-1 bg-slate-100 rounded-full overflow-hidden">
                  <div
                    id="read-progress"
                    class="h-full bg-teal rounded-full transition-[width] duration-100"
                    style="width: 0%"
                    role="progressbar"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    aria-valuenow="0"
                    aria-label="Reading progress"
                  ></div>
                </div>
              </div>
              <div>
                <p class="auth-toc-label">Share</p>
                <div class="flex items-center gap-2 mt-3">
                  <a
                    href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(pageUrl)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="auth-share-btn"
                    aria-label="Share on LinkedIn"
                  >
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  </a>
                  <a
                    href={`mailto:?subject=${encodeURIComponent(h1)}&body=${encodeURIComponent('I thought this might be useful: ' + pageUrl)}`}
                    class="auth-share-btn"
                    aria-label="Share via email"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                  </a>
                  <button
                    id="copy-link-btn"
                    class="auth-share-btn"
                    data-url={pageUrl}
                    aria-label="Copy link"
                    type="button"
                  >
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </aside>

          <!-- ─── MAIN CONTENT COLUMN ─────────────────────────────────────── -->
          <div class="min-w-0 max-w-[680px]">

            <!-- Mobile TOC accordion -->
            <details class="lg:hidden mb-8 bg-slate-50 border border-slate-200 rounded-xl overflow-hidden">
              <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none list-none text-sm font-semibold text-slate-700 hover:text-teal transition-colors">
                <span>On this page</span>
                <svg class="w-4 h-4 auth-toc-chevron transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                </svg>
              </summary>
              <div class="px-5 pb-4 pt-1">
                <nav id="toc-mobile" aria-label="Case study sections (mobile)"></nav>
              </div>
            </details>

            <!-- Body -->
            <div class="authority-body cs-body">
              <slot />

              <!-- What This Demonstrates -->
              {keyTakeaways.length > 0 && (
                <Fragment>
                  <h2>What This Demonstrates</h2>
                  <div class="cs-takeaways" data-speakable="true">
                    <p class="takeaways-eyebrow">Key Takeaways</p>
                    <ul>
                      {keyTakeaways.map(t => <li>{t}</li>)}
                    </ul>
                  </div>
                </Fragment>
              )}

              <!-- Why This Matters for Procurement -->
              {procurementCallout && (
                <div class="cs-procurement-callout">
                  <p class="cs-callout-label">Why This Matters for Procurement</p>
                  <p class="cs-callout-text">{procurementCallout}</p>
                </div>
              )}
            </div>

          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════ RELATED CONTENT ══════════════════════════════════ -->
    <section class="bg-white border-t border-slate-100 py-12 lg:py-16" aria-label="Related content">
      <div class="max-w-screen-xl mx-auto px-4 sm:px-6">

        <div class="mb-10">
          <p class="text-xs font-bold tracking-widest uppercase text-teal mb-2">Go Deeper</p>
          <h2 class="text-xl font-bold text-[#0a0f1a] font-display mb-5">Related Authority Page</h2>
          <a
            href={relatedAuthority.href}
            class="group inline-flex flex-col sm:flex-row sm:items-center gap-4 bg-white border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:shadow-md transition-all duration-200 max-w-xl"
          >
            <div class="h-1 sm:h-auto sm:w-1 sm:self-stretch" style={`background: ${relatedAuthority.color ?? '#14b8a6'}`} aria-hidden="true"></div>
            <div class="p-5 sm:py-5 sm:pr-6">
              <p class="text-xs font-bold tracking-widest uppercase mb-1" style={`color: ${relatedAuthority.color ?? '#14b8a6'}`}>Authority Page</p>
              <h3 class="text-sm font-bold text-[#0f172a] mb-1 group-hover:text-teal transition-colors">{relatedAuthority.label}</h3>
              {relatedAuthority.desc && <p class="text-xs text-slate-500 leading-relaxed">{relatedAuthority.desc}</p>}
              <span class="text-xs text-teal font-semibold mt-2 inline-block">Read more →</span>
            </div>
          </a>
        </div>

        {relatedArticles.length > 0 && (
          <div>
            <p class="text-xs font-bold tracking-widest uppercase text-teal mb-2">More Reading</p>
            <h2 class="text-xl font-bold text-[#0a0f1a] font-display mb-5">Related Articles</h2>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
              {relatedArticles.map(a => (
                <a
                  href={a.href}
                  class="group block bg-white border border-slate-200 rounded-xl overflow-hidden hover:border-slate-300 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200"
                >
                  <div class="h-1" style={`background: ${a.clusterColor}`} aria-hidden="true"></div>
                  <div class="p-5">
                    <p class="text-[10px] font-bold tracking-widest uppercase mb-2" style={`color: ${a.clusterColor}`}>{a.cluster} · {a.readTime} min</p>
                    <h3 class="text-sm font-bold text-[#0f172a] mb-2 group-hover:text-teal transition-colors leading-snug">{a.title}</h3>
                    <p class="text-xs text-slate-500 leading-relaxed line-clamp-3">{a.excerpt}</p>
                    <span class="text-xs text-teal font-semibold mt-3 inline-block">Read →</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="pt-6 border-t border-slate-100">
          <p class="text-sm text-slate-600 mb-3">Ready to discuss your facility's cleaning requirements?</p>
          <a
            href="/request-a-proposal/"
            class="inline-flex items-center px-5 py-2.5 bg-teal text-navy font-bold text-sm rounded hover:bg-teal-bright transition-colors shadow"
          >
            Get a Proposal →
          </a>
        </div>

      </div>
    </section>

    <DualCTA />

  </main>

  <Footer />
</BaseLayout>

<style is:global>

/* ─── Stat cards ─────────────────────────────────────────────────────────── */
.cs-stat-card {
  text-align: center;
  padding: 1rem;
  border-right: 1px solid #f1f5f9;
}
.cs-stat-card:last-child {
  border-right: none;
}
@media (max-width: 767px) {
  .cs-stat-card:nth-child(even) { border-right: none; }
  .cs-stat-card:nth-child(1),
  .cs-stat-card:nth-child(2) { border-bottom: 1px solid #f1f5f9; }
}
.cs-stat-value {
  font-family: 'Inter Display', 'Inter', sans-serif;
  font-size: clamp(1.625rem, 3.5vw, 2.5rem);
  font-weight: 900;
  color: #14b8a6;
  line-height: 1.1;
  margin-bottom: 0.5rem;
  letter-spacing: -0.02em;
}
.cs-stat-label {
  font-size: 0.8125rem;
  color: #64748b;
  line-height: 1.5;
  font-weight: 500;
}

/* ─── Key Takeaways (cs-takeaways) ─────────────────────────────────────── */
.cs-takeaways {
  background: #f0fdfa;
  border-left: 4px solid #14b8a6;
  border-radius: 0 0.75rem 0.75rem 0;
  padding: 1.5rem 1.75rem;
  margin-bottom: 2rem;
}
.cs-takeaways .takeaways-eyebrow {
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #14b8a6;
  margin-bottom: 0.875rem;
  display: block;
}
.cs-takeaways ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.cs-takeaways ul li {
  position: relative;
  padding-left: 1.75rem;
  margin-bottom: 0.625rem;
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.65;
}
.cs-takeaways ul li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 7px;
  height: 7px;
  background: #14b8a6;
  border-radius: 1px;
  transform: rotate(45deg);
}

/* ─── Procurement callout ─────────────────────────────────────────────── */
.cs-procurement-callout {
  background: #f8fafc;
  border-left: 4px solid #14b8a6;
  border-radius: 0 0.75rem 0.75rem 0;
  padding: 1.5rem 1.75rem;
  margin-top: 2rem;
  margin-bottom: 2rem;
}
.cs-callout-label {
  font-size: 0.625rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #14b8a6;
  margin-bottom: 0.625rem;
  display: block;
}
.cs-callout-text {
  font-size: 0.9375rem;
  color: #334155;
  line-height: 1.75;
  margin: 0;
}

</style>

<script>
  const csBody = document.querySelector<HTMLElement>('.cs-body')
  const tocDesktop = document.getElementById('toc')
  const tocMobile = document.getElementById('toc-mobile')

  function slugify(text: string): string {
    return text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')
  }

  if (csBody) {
    const headings = Array.from(csBody.querySelectorAll<HTMLHeadingElement>('h2'))

    headings.forEach(h => {
      const slug = slugify(h.textContent?.trim() ?? '')
      h.id = slug
      const makeLink = () => {
        const a = document.createElement('a')
        a.href = `#${slug}`
        a.textContent = h.textContent?.trim() ?? ''
        a.className = 'toc-link'
        return a
      }
      tocDesktop?.appendChild(makeLink())
      tocMobile?.appendChild(makeLink())
    })

    const allLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link')
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            allLinks.forEach(l => l.classList.remove('toc-active'))
            document.querySelectorAll<HTMLAnchorElement>(`.toc-link[href="#${e.target.id}"]`)
              .forEach(l => l.classList.add('toc-active'))
          }
        })
      },
      { rootMargin: '-20% 0px -70% 0px' }
    )
    headings.forEach(h => observer.observe(h))

    const bar = document.getElementById('read-progress')
    const pct = document.getElementById('progress-pct')
    const updateProgress = () => {
      const { top, height } = csBody.getBoundingClientRect()
      const scrolled = Math.max(0, -top)
      const total = Math.max(1, height - window.innerHeight)
      const p = Math.min(100, Math.round((scrolled / total) * 100))
      if (bar) { bar.style.width = `${p}%`; bar.setAttribute('aria-valuenow', String(p)) }
      if (pct) { pct.textContent = `${p}%` }
    }
    window.addEventListener('scroll', updateProgress, { passive: true })
    updateProgress()
  }

  document.getElementById('copy-link-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('copy-link-btn') as HTMLButtonElement
    const url = btn?.dataset.url ?? window.location.href
    try {
      await navigator.clipboard.writeText(url)
      btn.style.background = '#14b8a6'
      btn.style.color = 'white'
      setTimeout(() => { btn.style.background = ''; btn.style.color = '' }, 1500)
    } catch { /* ignore */ }
  })
</script>
