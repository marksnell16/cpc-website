---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import DualCTA from '../../components/global/DualCTA.astro'

const caseStudies = [
  {
    cluster: "Government",
    clusterColor: "#3b82f6",
    title: "252 Sites Across Queensland. 28 Years of Compliant Government Cleaning.",
    standfirst: "Continuous delivery under the QBuild Panel since 1997, across metro, regional and remote Queensland, under three ISO certifications.",
    metaLine: "Government · Queensland Statewide · Since 1997",
    outcomes: ["252 sites", "28+ years", "3 ISO certs"],
    href: "/case-studies/queensland-government-statewide/",
  },
  {
    cluster: "Industrial",
    clusterColor: "#f59e0b",
    title: "Live Industrial Environments. Mining, Resources and Heavy Industry Cleaning Capability.",
    standfirst: "Multi-site national portfolio across mining equipment maintenance facilities and heavy industrial operations, with documented zero-LTI WHS performance.",
    metaLine: "Industrial · National · Multi-site portfolio",
    outcomes: ["Zero LTIs", "100% permit compliance", "ISO 45001 certified"],
    href: "/case-studies/industrial-resources-cleaning/",
  },
  {
    cluster: "Education",
    clusterColor: "#f43f5e",
    title: "NSW Government Schools Panel. Sydney Metro and Multi-Sector Education Capability.",
    standfirst: "Active panel supplier under the NSW Department of Education SINSW framework, covering 200+ Sydney metro schools plus reactive maintenance contracts.",
    metaLine: "Education · NSW + Multi-Sector · Active Panel Position",
    outcomes: ["200+ schools", "Zero WWCC breaches", "SINSW panel active"],
    href: "/case-studies/education-multi-panel-capability/",
  },
  {
    cluster: "Carbon",
    clusterColor: "#10b981",
    title: "100% Carbon Neutral Cleaning. Proprietary Calculation Across Scope 1, 2 and 3.",
    standfirst: "Verified emissions tracking and 100% offset across the full portfolio. Site-level reporting for ESG disclosure. Applicable to every CPC contract.",
    metaLine: "Sustainability · Cross-sector · Applicable to all contracts",
    outcomes: ["100% carbon neutral", "Scope 1+2+3", "Site-level reports"],
    href: "/case-studies/carbon-neutral-cleaning-program/",
  },
]
---

<DefaultLayout
  title="Case Studies: Proof at Scale. CPC"
  description="Real outcomes from CPC's national portfolio across government, industrial, education and sustainability contracts: compliance evidence, operational scale and sector-specific capability."
  breadcrumbs={[
    { name: "Home", url: "https://cpclean.com.au/" },
    { name: "Case Studies", url: "https://cpclean.com.au/case-studies/" },
  ]}
>

  <!-- Hero -->
  <section class="bg-[#0a0f1a] pt-20 pb-14">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <p class="text-xs font-bold tracking-widest uppercase text-teal mb-4">Proof at Scale</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-5 max-w-2xl">Case Studies</h1>
      <p class="text-lg text-slate-400 leading-relaxed max-w-xl">Real outcomes from CPC's national portfolio. Government, industrial, education and sustainability. Documented evidence, not assurances.</p>
    </div>
  </section>

  <!-- Grid -->
  <section class="bg-slate-50 py-14">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="grid sm:grid-cols-2 gap-5">
        {caseStudies.map(cs => (
          <a href={cs.href} class="cs-idx-card group">
            <div class="cs-idx-top-bar" style={`background: ${cs.clusterColor}`}></div>
            <div class="cs-idx-body">
              <div class="flex items-center gap-2 mb-4">
                <span
                  class="cs-idx-pill"
                  style={`background:${cs.clusterColor}18;color:${cs.clusterColor};border:1px solid ${cs.clusterColor}30`}
                >
                  {cs.cluster}
                </span>
                <span class="text-xs text-slate-400 font-medium">{cs.metaLine.split('·').slice(1).join('·').trim()}</span>
              </div>
              <h2 class="cs-idx-title group-hover:text-teal transition-colors">{cs.title}</h2>
              <p class="cs-idx-standfirst">{cs.standfirst}</p>
              <div class="cs-idx-outcomes">
                {cs.outcomes.map(o => (
                  <span class="cs-idx-outcome-chip" style={`color:${cs.clusterColor};border-color:${cs.clusterColor}30;background:${cs.clusterColor}0f`}>{o}</span>
                ))}
              </div>
              <span class="cs-idx-read-link" style={`color: ${cs.clusterColor}`}>Read case study →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <DualCTA />

</DefaultLayout>

<style is:global>
  .cs-idx-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 0.875rem;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .cs-idx-card:hover {
    box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }
  .cs-idx-top-bar {
    height: 4px;
    flex-shrink: 0;
  }
  .cs-idx-body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .cs-idx-pill {
    display: inline-block;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .cs-idx-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: #0a0f1a;
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }
  .cs-idx-standfirst {
    font-size: 0.875rem;
    color: #64748b;
    line-height: 1.65;
    margin-bottom: 1.25rem;
    flex: 1;
  }
  .cs-idx-outcomes {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.25rem;
  }
  .cs-idx-outcome-chip {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    border: 1px solid;
  }
  .cs-idx-read-link {
    font-size: 0.8125rem;
    font-weight: 700;
    display: inline-block;
  }
</style>
