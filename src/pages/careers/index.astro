---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import DualCTA from '../../components/global/DualCTA.astro'

const benefits = [
  {
    title: 'Direct employment: not an agency',
    text: 'You work for CPC, not through a labour hire firm. Real entitlements, job security, award wages and a team that knows your name.',
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>`,
  },
  {
    title: 'Stable, consistent shifts',
    text: 'Government and institutional contracts mean predictable rosters, not last-minute casual calls. Build your week around work you can count on.',
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>`,
  },
  {
    title: 'CPC Academy: your training pathway',
    text: 'Our in-house training program takes you from day one through to certified professional, and on to leadership if that\'s where you want to go.',
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 3.741-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"/></svg>`,
  },
  {
    title: 'Recognition every month',
    text: 'Monthly and quarterly awards, newsletter shoutouts and real cash rewards for team members who go above and beyond. Your work gets noticed.',
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 0 1 3 3h-15a3 3 0 0 1 3-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 0 1-.982-3.172M9.497 14.25a7.454 7.454 0 0 0 .981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 0 0 7.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M7.73 9.728a6.726 6.726 0 0 0 2.748 1.35m8.272-6.842V4.5c0 2.108-.966 3.99-2.48 5.228m2.48-5.492a46.32 46.32 0 0 1 2.916.52 6.003 6.003 0 0 1-5.395 4.972m0 0a6.726 6.726 0 0 1-2.749 1.35m0 0a6.772 6.772 0 0 1-3.044 0"/></svg>`,
  },
  {
    title: 'An inclusive team',
    text: '58% female. 10% Indigenous. Team members who speak more than a dozen languages. We actively build a team where everyone is genuinely welcome.',
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3.75 3.75 0 1 1-6 0 3.75 3.75 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>`,
  },
  {
    title: 'A real path forward',
    text: 'Many of our supervisors and area managers started exactly where you are. CPC promotes from within, and your next step is available from day one.',
    icon: `<svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>`,
  },
]

const roles = [
  {
    title: 'Commercial Cleaner',
    type: 'Permanent Part-Time',
    locations: ['Brisbane', 'Sydney', 'Melbourne', 'Perth'],
    desc: 'Cleaning of commercial, government and institutional buildings. Early morning, daytime and evening shifts available. No experience required. Full training provided through CPC Academy.',
    reqs: ['Reliable and punctual', 'Available for regular shifts', 'Willing to complete CPC induction and Academy training', 'Police check required for some sites'],
  },
  {
    title: 'Leading Hand Cleaner',
    type: 'Permanent Full-Time',
    locations: ['Brisbane', 'Townsville'],
    desc: 'Support the site supervisor in day-to-day operations. Includes staff coordination, quality checks, stock management and reporting. Suited to experienced cleaners ready for more responsibility.',
    reqs: ['12+ months cleaning experience', 'Reliability and strong work ethic', 'Basic written communication', 'Current police check'],
  },
  {
    title: 'Site Supervisor',
    type: 'Permanent Full-Time',
    locations: ['Brisbane', 'Sydney', 'Melbourne'],
    desc: 'Oversee cleaning operations across one or more sites. Responsible for staff scheduling, quality inspections, client communication and compliance documentation.',
    reqs: ['Previous supervisory experience preferred', 'Strong written and verbal communication', 'Competent with mobile reporting tools', 'Valid driver licence', 'Police check required'],
  },
  {
    title: 'Specialist Cleaner (Industrial)',
    type: 'Contract / Project',
    locations: ['Queensland', 'Western Australia'],
    desc: 'Cleaning of industrial, mining and resources facilities. Work is project-based during planned shutdowns. High-pressure cleaning, confined space work and hazardous area protocols apply.',
    reqs: ['Confined space entry certificate', 'High pressure water blasting experience', 'Ability to pass site-specific medicals and drug and alcohol screening', 'FIFO availability advantageous'],
  },
]
---

<DefaultLayout
  title="Careers at CPC | Direct Employment, Award Wages & Real Development"
  description="Direct employment, award wages, CPC Academy training and a genuine path to leadership. Hiring across QLD, NSW, VIC, WA and SA right now. Apply today."
  breadcrumbs={[
    { name: 'Home', url: 'https://cpclean.com.au/' },
    { name: 'Careers', url: 'https://cpclean.com.au/careers/' },
  ]}
>

  <!-- Hero -->
  <section class="bg-[#0a0f1a] py-20 lg:py-28">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-4">Careers at CPC</p>
        <h1 class="text-4xl lg:text-5xl font-black text-white leading-tight tracking-tight mb-6">
          Why work for CPC?
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed max-w-2xl mb-4">
          Direct employment. Stable shifts. Real training. Monthly recognition. And a genuine path from cleaner to leader, if that is where you want to go.
        </p>
        <p class="text-sm text-slate-400 leading-relaxed max-w-2xl mb-8">
          This is not casual agency work. This is a career with a company that invests in its people.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#positions" class="inline-flex items-center px-6 py-3 bg-teal text-[#0a0f1a] font-bold text-sm rounded-lg hover:bg-teal-bright transition-colors">
            View open positions →
          </a>
          <a href="/about/our-team/" class="inline-flex items-center px-6 py-3 border border-white/20 text-white font-semibold text-sm rounded-lg hover:border-teal/60 hover:text-teal transition-colors">
            Meet the team
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why CPC -->
  <section class="bg-white py-16 lg:py-24 border-b border-slate-100">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-3">Why CPC</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy leading-tight">What makes CPC different as an employer</h2>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map(b => (
          <div class="relative bg-white border border-slate-200 rounded-xl p-6 overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1 bg-teal rounded-t-xl"></div>
            <div class="text-teal mb-4 mt-1" set:html={b.icon} />
            <h3 class="text-base font-bold text-navy mb-2">{b.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{b.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Career pathway -->
  <section class="bg-[#0a0f1a] py-16 lg:py-20">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mb-10">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-3">CPC Academy</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-4">
          We develop professionals,<br class="hidden sm:block" /> not just cleaners.
        </h2>
        <p class="text-slate-300 leading-relaxed">
          CPC Academy is our in-house training and development program. Every module you complete builds real skills, real confidence, and real opportunities within CPC. Our training is aligned to Certificate III in Cleaning Operations and built for real site conditions, not theory. You don't need experience to start. We train everything from day one.
        </p>
      </div>

      <div class="bg-white/5 border border-white/10 rounded-xl p-6 lg:p-8 max-w-3xl">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-6">Your Career Pathway</p>
        <div class="flex flex-wrap items-center gap-2">
          {[
            { step: 'Cleaner', sub: 'Your starting point' },
            { step: 'CPC Academy', sub: 'Skills and certification' },
            { step: 'Leading Hand', sub: 'More responsibility' },
            { step: 'Site Supervisor', sub: 'Run your own site' },
            { step: 'Area Manager', sub: 'Lead multiple teams' },
          ].map((p, i, arr) => (
            <>
              <div class="flex flex-col items-center text-center min-w-[80px]">
                <div class={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold mb-2 ${i === 0 ? 'bg-teal text-[#0a0f1a]' : 'bg-white/10 text-white'}`}>
                  {i + 1}
                </div>
                <p class="text-xs font-bold text-white leading-tight">{p.step}</p>
                <p class="text-xs text-slate-400 mt-0.5">{p.sub}</p>
              </div>
              {i < arr.length - 1 && (
                <div class="text-slate-600 text-lg font-bold flex-shrink-0">→</div>
              )}
            </>
          ))}
        </div>
        <p class="text-xs text-slate-400 mt-6 border-t border-white/10 pt-4">
          This is not a theoretical pathway. Many of our current supervisors and area managers progressed through this exact structure.
        </p>
      </div>
    </div>
  </section>

  <!-- Current Positions -->
  <section class="bg-slate-50 py-16 lg:py-24 border-b border-slate-100" id="positions">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="mb-12">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-3">Open Positions</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy leading-tight mb-3">Roles we're hiring for now</h2>
        <p class="text-slate-500 text-sm leading-relaxed max-w-xl">
          We're growing across all states. You don't need years of experience to apply. We hire for attitude, reliability and long-term potential, then build capability through structured training and leadership pathways.
        </p>
      </div>

      <div class="space-y-5">
        {roles.map(r => (
          <div class="bg-white border border-slate-200 rounded-xl p-6 lg:p-8">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 mb-4">
              <div>
                <h3 class="text-lg font-bold text-navy">{r.title}</h3>
                <div class="flex flex-wrap gap-2 mt-2">
                  <span class="text-xs font-semibold px-2.5 py-1 bg-teal/10 text-teal rounded-full">{r.type}</span>
                  {r.locations.map(l => (
                    <span class="text-xs font-medium px-2.5 py-1 bg-slate-100 text-slate-600 rounded-full">{l}</span>
                  ))}
                </div>
              </div>
              <a
                href="#apply"
                class="flex-shrink-0 inline-flex items-center px-4 py-2 bg-teal text-[#0a0f1a] font-bold text-xs rounded-lg hover:bg-teal-bright transition-colors"
              >
                Apply →
              </a>
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">{r.desc}</p>
            <div>
              <p class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">What we're looking for:</p>
              <ul class="grid sm:grid-cols-2 gap-1.5">
                {r.reqs.map(req => (
                  <li class="flex items-start gap-2 text-sm text-slate-600">
                    <svg class="w-3.5 h-3.5 text-teal mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                    </svg>
                    {req}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <!-- Relocation note -->
      <div class="mt-8 bg-white border border-teal/20 rounded-xl p-5 max-w-2xl">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-2">Relocation Opportunities</p>
        <p class="text-sm text-slate-600 leading-relaxed">
          CPC operates nationally across metropolitan, regional and remote locations. We support relocation opportunities across Australia for high-performing team members who demonstrate the right capability, attitude and leadership potential. Mention your interest in relocation when you apply.
        </p>
      </div>
    </div>
  </section>

  <!-- Apply -->
  <section class="bg-white py-16 lg:py-24" id="apply">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-3">Apply</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-navy leading-tight mb-4">
          Ready to join CPC?
        </h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          Send your name, the state you're in, the role you're interested in, and any certifications or clearances you hold to our HR team. Every application is reviewed by our internal team. We do not use labour hire or automated screening processes.
        </p>
        <p class="text-slate-600 leading-relaxed mb-8">
          Not sure which role suits you? Tell us a bit about your experience and availability and we'll point you in the right direction.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 items-start">
          <a
            href="mailto:contact@cpclean.com.au"
            class="inline-flex items-center gap-2 px-6 py-3 bg-teal text-[#0a0f1a] font-bold text-sm rounded-lg hover:bg-teal-bright transition-colors"
          >
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"/>
            </svg>
            contact@cpclean.com.au
          </a>
          <div class="text-sm text-slate-400 pt-2">Response within 1 business day.</div>
        </div>
      </div>
    </div>
  </section>

  <DualCTA />

</DefaultLayout>
