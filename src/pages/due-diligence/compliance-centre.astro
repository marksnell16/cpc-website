---
import DDHubLayout from '../../layouts/DDHubLayout.astro'
import CertCard from '../../components/dd/CertCard.astro'
import DocRow from '../../components/dd/DocRow.astro'
import DualCTA from '../../components/global/DualCTA.astro'
---

<DDHubLayout
  title="Compliance Centre: ISO Certifications & Accreditation — CPC Due Diligence Hub"
  description="CPC holds three ISO certifications issued by SAI Global, a JAS-ANZ accredited certification body. View certification details, audit cycle, and all compliance documentation available for procurement evaluation."
  breadcrumbs={[
    { name: 'Home', url: 'https://cpclean.com.au/' },
    { name: 'Due Diligence Hub', url: 'https://cpclean.com.au/due-diligence/' },
    { name: 'Compliance Centre', url: 'https://cpclean.com.au/due-diligence/compliance-centre/' },
  ]}
>

  <!-- Hero -->
  <section class="bg-[#0a0f1a] py-16 lg:py-24">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-3">Compliance Centre</p>
        <h1 class="text-4xl lg:text-5xl font-black text-white leading-tight tracking-tight mb-6">
          Three ISO certifications.<br class="hidden sm:block" /> One JAS-ANZ accredited body.<br class="hidden sm:block" /> Independently verified.
        </h1>
        <p class="text-lg text-slate-300 leading-relaxed max-w-2xl">
          All certifications are issued by SAI Global under JAS-ANZ accreditation — government-recognised independent verification, not self-declaration.
        </p>
      </div>
    </div>
  </section>

  <!-- ISO Certifications -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold text-navy mb-2">ISO Certifications Held</h2>
        <p class="text-slate-600 leading-relaxed mb-8">
          CPC holds three current ISO certifications across quality, environmental and occupational health and safety management. All certifications are issued by SAI Global, a JAS-ANZ accredited certification body, and are subject to annual surveillance audits and three-year re-certification cycles.
        </p>
        <div class="grid gap-5 sm:grid-cols-1 lg:grid-cols-3">
          <CertCard
            title="Quality Management System"
            standard="ISO 9001:2015"
            issuer="SAI Global (JAS-ANZ accredited)"
            scope="Commercial cleaning services across all CPC operational sites"
            color="#dc2626"
          />
          <CertCard
            title="Environmental Management System"
            standard="ISO 14001:2015"
            issuer="SAI Global (JAS-ANZ accredited)"
            scope="Environmental management across CPC cleaning operations nationally"
            color="#16a34a"
          />
          <CertCard
            title="Occupational Health & Safety Management"
            standard="ISO 45001:2018"
            issuer="SAI Global (JAS-ANZ accredited)"
            scope="WHS management for all CPC staff and contractor operations"
            color="#d97706"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- JAS-ANZ Accreditation -->
  <section class="bg-slate-50 py-16 lg:py-20">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold text-navy mb-4">What JAS-ANZ Accreditation Means</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          JAS-ANZ — the Joint Accreditation System of Australia and New Zealand — is the government-recognised accreditation authority for conformity assessment bodies operating in Australia and New Zealand. When a certification body such as SAI Global operates under JAS-ANZ accreditation, it means their certification processes have been independently evaluated against internationally recognised standards and found to be competent and impartial.
        </p>
        <p class="text-slate-600 leading-relaxed mb-4">
          For procurement teams, this distinction is material. ISO certifications issued by JAS-ANZ accredited bodies are independently verified — the certification body itself is subject to ongoing oversight and re-evaluation. Certifications issued by non-accredited bodies carry no equivalent assurance; they may reflect a self-assessment process rather than genuine independent audit.
        </p>
        <p class="text-slate-600 leading-relaxed">
          All three of CPC's ISO certifications are issued by SAI Global under JAS-ANZ accreditation. Full details of JAS-ANZ and accredited certification bodies are available at{' '}
          <a
            href="https://www.jas-anz.org"
            target="_blank"
            rel="noopener noreferrer"
            class="text-teal font-medium hover:underline"
          >
            jas-anz.org
          </a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Audit Cycle -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold text-navy mb-4">Audit Cycle and Currency</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          Each ISO certification follows a structured audit cycle comprising an annual surveillance audit and a full re-certification audit every three years. Surveillance audits verify that the management system remains operational and effective; re-certification audits involve a comprehensive re-evaluation of the entire system against the relevant standard.
        </p>
        <p class="text-slate-600 leading-relaxed mb-4">
          CPC's certifications are current and have been maintained without lapse. Copies of current certificates — including the certification number, scope, issue date and expiry date — are available to procurement teams on request. Certificates can be provided within one business day of a request, along with the name and accreditation number of the issuing body for independent verification.
        </p>
        <p class="text-slate-600 leading-relaxed">
          For tender submissions requiring certificate copies, contact <a href="mailto:compliance@cpclean.com.au" class="text-teal font-medium hover:underline">compliance@cpclean.com.au</a> with your tender reference and the specific documents required.
        </p>
      </div>
    </div>
  </section>

  <!-- Additional compliance docs table -->
  <section class="bg-slate-50 py-16 lg:py-20">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold text-navy mb-2">Additional Compliance Documentation</h2>
        <p class="text-slate-600 leading-relaxed mb-8">
          Beyond ISO certifications, CPC maintains a full suite of compliance documentation available to procurement teams. All documents listed below are available on request unless otherwise noted.
        </p>
        <div class="overflow-x-auto rounded-xl border border-slate-200">
          <table class="w-full bg-white text-left">
            <thead>
              <tr class="border-b border-slate-200 bg-slate-50">
                <th class="py-3 px-4 text-xs font-bold text-slate-500 uppercase tracking-wide w-28">Type</th>
                <th class="py-3 px-4 text-xs font-bold text-slate-500 uppercase tracking-wide">Document</th>
                <th class="py-3 px-4 text-xs font-bold text-slate-500 uppercase tracking-wide text-right">Availability</th>
              </tr>
            </thead>
            <tbody>
              <DocRow
                title="Modern Slavery Statement"
                description="Annual report under the Modern Slavery Act 2018 (Cth) covering supply chain mapping, risk assessment and remediation actions."
                type="Statement"
                available={false}
              />
              <DocRow
                title="WHS Management Plan"
                description="Documented workplace health and safety management system aligned to ISO 45001 requirements."
                type="Policy"
                available={true}
              />
              <DocRow
                title="Environmental Management Plan"
                description="Operational environmental management procedures aligned to ISO 14001 requirements."
                type="Policy"
                available={true}
              />
              <DocRow
                title="Quality Management Manual"
                description="Documented quality management procedures and processes aligned to ISO 9001 requirements."
                type="Policy"
                available={true}
              />
              <DocRow
                title="Public Liability Insurance Certificate"
                description="$20 million public liability coverage. Certificate of currency provided with each contract."
                type="Certificate"
                available={true}
              />
              <DocRow
                title="Professional Indemnity Insurance"
                description="Professional indemnity coverage. Certificate of currency available for tender submissions."
                type="Certificate"
                available={true}
              />
              <DocRow
                title="Workers Compensation: All States"
                description="Workers compensation coverage across all states and territories in which CPC operates."
                type="Certificate"
                available={true}
              />
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- carbon neutral -->
  <section class="bg-white py-16 lg:py-20">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-4xl">
        <h2 class="text-2xl font-bold text-navy mb-4">Carbon Neutral Certified Certification</h2>
        <p class="text-slate-600 leading-relaxed mb-4">
          CPC holds Carbon Neutral Certified certification under the Australian Government's carbon neutral program — the national standard for credible carbon neutral claims by Australian businesses. The certification covers Scope 1 (direct emissions), Scope 2 (purchased electricity) and Scope 3 (value chain emissions) as applicable to CPC's cleaning operations.
        </p>
        <p class="text-slate-600 leading-relaxed mb-4">
          The carbon neutral claim is independently verified by a carbon neutral approved auditor against the Carbon Neutral Certified Standard for Organisations. Verification and renewal occurs annually, with the certification registered on the carbon neutral website and available for public review.
        </p>
        <p class="text-slate-600 leading-relaxed">
          For contracts where carbon neutral cleaning is a specified requirement or a tender evaluation criterion, CPC can provide the carbon neutral certification record, the verified emissions inventory, and the offset documentation that supports the carbon neutral claim.
        </p>
      </div>
    </div>
  </section>

  <!-- Teal callout -->
  <section class="bg-slate-50 py-12 lg:py-16">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
      <div class="max-w-4xl">
        <div class="bg-teal/10 border border-teal/30 rounded-xl p-6 lg:p-8">
          <p class="text-sm font-bold text-teal uppercase tracking-widest mb-2">Tender Submissions</p>
          <p class="text-navy font-semibold text-lg mb-3">
            Need certificates for a tender submission?
          </p>
          <p class="text-slate-700 leading-relaxed">
            Email <a href="mailto:compliance@cpclean.com.au" class="font-bold text-teal hover:underline">compliance@cpclean.com.au</a> with your tender reference and the required documents. We respond within 1 business day with current, correctly formatted certificates and documentation ready for submission.
          </p>
        </div>
      </div>
    </div>
  </section>

  <DualCTA />

</DDHubLayout>
