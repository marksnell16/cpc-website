---
import DefaultLayout from '../layouts/DefaultLayout.astro'
---

<DefaultLayout
  title="Terms of Use. Commercial Property Cleaning"
  description="Terms of Use for Commercial Property Cleaning Pty Ltd."
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Terms of Use', url: '/terms/' }]}
>
  <section class="bg-white py-20">
    <div class="max-w-screen-md mx-auto px-4 sm:px-6">
      <h1 class="font-display text-4xl text-navy mb-6">Terms of Use</h1>
      <p class="text-slate-600 leading-relaxed">
        Terms of Use are being updated. Please contact
        <a href="mailto:info@cpclean.com.au" class="text-teal hover:text-teal-bright transition-colors">info@cpclean.com.au</a>
        for our current terms.
      </p>
    </div>
  </section>
</DefaultLayout>
