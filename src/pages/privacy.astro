---
import DefaultLayout from '../layouts/DefaultLayout.astro'
---

<DefaultLayout
  title="Privacy Policy. Commercial Property Cleaning"
  description="Privacy Policy for Commercial Property Cleaning Pty Ltd."
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Privacy Policy', url: '/privacy/' }]}
>
  <section class="bg-white py-20">
    <div class="max-w-screen-md mx-auto px-4 sm:px-6">
      <h1 class="font-display text-4xl text-navy mb-6">Privacy Policy</h1>
      <p class="text-slate-600 leading-relaxed">
        Privacy Policy is being updated. Please contact
        <a href="mailto:info@cpclean.com.au" class="text-teal hover:text-teal-bright transition-colors">info@cpclean.com.au</a>
        for our current policy.
      </p>
    </div>
  </section>
</DefaultLayout>
