---
const pathname = Astro.url.pathname

const navItems = [
  { label: 'Overview',           href: '/due-diligence/' },
  { label: 'Compliance Centre',  href: '/due-diligence/compliance-centre/' },
  { label: 'Social Procurement', href: '/due-diligence/social-procurement/' },
  { label: 'Management Approach',href: '/due-diligence/management-approach/' },
  { label: 'Testimonials',       href: '/due-diligence/testimonials/' },
  { label: 'Case Studies',       href: '/due-diligence/case-studies/' },
]

function isActive(href: string): boolean {
  if (href === '/due-diligence/') {
    return pathname === '/due-diligence/' || pathname === '/due-diligence'
  }
  return pathname.startsWith(href.replace(/\/$/, ''))
}
---

<nav
  class="sticky top-16 z-40 bg-white border-b border-slate-200"
  aria-label="Due Diligence Hub navigation"
>
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
    <div class="flex overflow-x-auto scrollbar-hide -mx-1">
      {navItems.map(item => {
        const active = isActive(item.href)
        return (
          <a
            href={item.href}
            class:list={[
              'flex-none whitespace-nowrap px-4 py-3.5 text-sm font-semibold border-b-2 transition-colors',
              active
                ? 'border-teal text-teal'
                : 'border-transparent text-slate-600 hover:text-navy hover:border-slate-300',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {item.label}
          </a>
        )
      })}
    </div>
  </div>
</nav>

<style>
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
