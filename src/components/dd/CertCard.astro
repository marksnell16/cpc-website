---
interface Props {
  title: string
  standard: string
  issuer: string
  scope: string
  color: string
  renewed?: string
}

const { title, standard, issuer, scope, color, renewed } = Astro.props
---

<div
  class="bg-white border border-slate-200 rounded-xl p-6 flex gap-5"
  style={`border-left: 4px solid ${color};`}
>
  <div class="flex-1 min-w-0">
    <!-- Standard badge -->
    <span
      class="inline-block text-xs font-bold tracking-wide uppercase px-2.5 py-1 rounded-full mb-3"
      style={`background:${color}18; color:${color}; border: 1px solid ${color}30;`}
    >
      {standard}
    </span>

    <h3 class="text-lg font-bold text-navy mb-1">{title}</h3>

    <p class="text-sm text-slate-500 font-medium mb-2">
      Issued by: {issuer}
    </p>

    <p class="text-sm text-slate-600 leading-relaxed">{scope}</p>

    {renewed && (
      <p class="mt-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">
        Renewed: {renewed}
      </p>
    )}
  </div>
</div>
