---
interface FAQItem {
  question: string
  answer: string
}

interface Props {
  title: string
  description: string
  slug: string
  serviceType: string
  areaServed?: string[]
  faqs?: FAQItem[]
}

const {
  title,
  description,
  slug,
  serviceType,
  areaServed = ['Australia'],
  faqs = [],
} = Astro.props

const siteUrl = 'https://cpclean.com.au'
const url = `${siteUrl}/authority/${slug}/`

const schemas: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": title,
    "description": description,
    "url": url,
    "provider": {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      "name": "Commercial Property Cleaning"
    },
    "serviceType": serviceType,
    "areaServed": areaServed.map(area => ({
      "@type": "Country",
      "name": area
    })),
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": `${title} Services`
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "url": url,
    "name": title,
    "description": description,
    "isPartOf": { "@id": `${siteUrl}/#website` },
    "about": { "@id": `${siteUrl}/#organization` },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".auth-tldr-block", ".auth-subtitle"]
    }
  }
]

if (faqs.length > 0) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "url": url,
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })
}
---

{schemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
