---
interface Stat {
  value: string
  label: string
  sub?: string
}

interface Props {
  stats?: Stat[]
}

const { stats = [
  { value: '500+', label: 'Staff Nationally',     sub: 'Workforce nationally' },
  { value: '250+', label: 'Government Sites',     sub: 'Federal and state' },
  { value: '3',    label: 'ISO Certifications',   sub: '9001 · 14001 · 45001' },
  { value: '30+',  label: 'Years Operating',      sub: 'Founded 1995' },
]} = Astro.props
---

<div class="bg-navy-800">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-12">
    <dl class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/5">
      {stats.map(stat => (
        <div class="bg-navy-800 px-8 py-10 text-center">
          <dt class="text-4xl md:text-5xl font-bold text-teal leading-none">{stat.value}</dt>
          <dd class="mt-2 text-sm font-semibold text-slate-200">{stat.label}</dd>
          {stat.sub && <dd class="mt-0.5 text-xs text-slate-500">{stat.sub}</dd>}
        </div>
      ))}
    </dl>
  </div>
</div>
