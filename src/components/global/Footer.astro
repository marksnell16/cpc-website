const sectors = [
  { label: 'Government & Defence',        href: '/authority/government-defence-cleaning/' },
  { label: 'Local Government & Councils', href: '/authority/local-government-council-cleaning/' },
  { label: 'Industrial & Power Station',  href: '/authority/industrial-power-station-cleaning/' },
  { label: 'Education & TAFE',            href: '/authority/education-tafe-cleaning/' },
  { label: 'Commercial Office Towers',    href: '/authority/commercial-office-tower-cleaning/' },
  { label: 'Carbon Neutral Cleaning',     href: '/authority/carbon-neutral-cleaning/' },
  { label: 'ISO Cleaning Provider',       href: '/authority/iso-cleaning-provider/' },
  { label: 'National Operations',         href: '/authority/national-cleaning-operations/' },
  { label: 'Technology & Robotics',       href: '/authority/cleaning-technology-robotics/' },
  { label: 'Modern Slavery & Ethical',    href: '/authority/modern-slavery-ethical-cleaning/' },
]

const hubLinks = [
  { label: 'Government Articles',   href: '/knowledge-hub/' },
  { label: 'Industrial Articles',   href: '/knowledge-hub/' },
  { label: 'Education Articles',    href: '/knowledge-hub/' },
  { label: 'Carbon Articles',       href: '/knowledge-hub/' },
  { label: 'Procurement Articles',  href: '/knowledge-hub/' },
  { label: 'Technology Articles',   href: '/knowledge-hub/' },
]

const companyLinks = [
  { label: 'About CPC',          href: '/about/' },
  { label: 'Careers',            href: '/careers/' },
  { label: 'Case Studies',       href: '/case-studies/' },
  { label: 'Knowledge Hub',      href: '/knowledge-hub/' },
  { label: 'Due Diligence Hub',  href: '/due-diligence/' },
  { label: 'Request a Proposal', href: '/request-a-proposal/' },
  { label: 'Contact',            href: '/contact/' },
]
---

<footer class="bg-navy text-slate-400">

  <!-- Main footer grid -->
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Brand + contact -->
      <div class="lg:col-span-1">
        <a href="/" class="flex-shrink-0" aria-label="Commercial Property Cleaning — Home">
          <img src="/images/logo/cpc-logo-white.svg" alt="Commercial Property Cleaning" class="h-9 w-auto" width="36" height="36" />
        </a>
        <p class="mt-4 text-sm leading-relaxed">
          Commercial Property Cleaning: ISO-certified, carbon neutral cleaning services across Australia.
          Government, industrial, education and corporate sectors.
        </p>
        <div class="mt-5 space-y-1.5 text-sm">
          <p class="text-white/40 text-xs font-semibold uppercase tracking-wider">Brisbane (HQ)</p>
          <p class="text-xs text-slate-400">81 Dunhill Cres, Morningside QLD 4170</p>
          <a href="/contact/#offices" class="text-xs text-teal hover:text-teal-bright transition-colors">View all 5 office addresses →</a>
        </div>
        <div class="mt-5 space-y-1 text-sm">
          <p><a href="tel:1300272888" class="hover:text-white transition-colors font-semibold text-white/80">1300 272 888</a></p>
          <p><a href="mailto:contact@cpclean.com.au" class="hover:text-white transition-colors">contact@cpclean.com.au</a></p>
          <p><a href="mailto:sales@cpclean.com.au" class="hover:text-white transition-colors">sales@cpclean.com.au</a></p>
          <p class="text-xs text-slate-500">Office hours: 8am – 6pm AEST</p>
        </div>
        <div class="mt-5 flex gap-3">
          <a
            href="https://linkedin.com/company/commercial-property-cleaning"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-white transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Sectors -->
      <div>
        <h3 class="text-white text-sm font-bold tracking-widest uppercase mb-5">Sectors</h3>
        <ul class="space-y-2.5">
          {sectors.map(s => (
            <li>
              <a href={s.href} class="text-sm hover:text-teal transition-colors">{s.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Knowledge Hub -->
      <div>
        <h3 class="text-white text-sm font-bold tracking-widest uppercase mb-5">Knowledge Hub</h3>
        <ul class="space-y-2.5">
          {hubLinks.map(l => (
            <li>
              <a href={l.href} class="text-sm hover:text-teal transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>
        <a href="/knowledge-hub/" class="inline-block mt-5 text-sm font-semibold text-teal hover:text-teal-bright transition-colors">
          All 30 articles →
        </a>
      </div>

      <!-- Col 4: Company -->
      <div>
        <h3 class="text-white text-sm font-bold tracking-widest uppercase mb-5">Company</h3>
        <ul class="space-y-2.5">
          {companyLinks.map(l => (
            <li>
              <a href={l.href} class="text-sm hover:text-teal transition-colors">{l.label}</a>
            </li>
          ))}
        </ul>

        <div class="mt-6 p-4 border border-white/10 rounded-lg">
          <p class="text-xs font-bold text-white mb-2">Certifications</p>
          <p class="text-xs leading-relaxed">ISO 9001 · ISO 14001 · ISO 45001</p>
          <p class="text-xs leading-relaxed mt-1">Carbon Neutral (Verified)</p>
          <p class="text-xs leading-relaxed mt-1">Modern Slavery Statement (Annual)</p>
          <p class="text-xs leading-relaxed mt-1">JAS-ANZ Accredited</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Sub-footer -->
  <div class="border-t border-white/10">
    <div class="max-w-screen-xl mx-auto px-4 sm:px-6 py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs">
      <p>© <time datetime="2026">2026</time> Commercial Property Cleaning Pty Ltd. All rights reserved.</p>
      <!-- ⚠️ CONFIRM WITH MARK: verify ACN 069 158 710 before go-live -->
      <p>ABN 72 069 158 710 · ACN 069 158 710 · Australian-owned and operated</p>
      <div class="flex gap-4">
        <a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms/" class="hover:text-white transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
