---
const items = [
  { label: 'ISO 9001',           sub: 'Quality Management' },
  { label: 'ISO 14001',          sub: 'Environmental' },
  { label: 'ISO 45001',          sub: 'Safety Management' },
  { label: 'Carbon Neutral',     sub: 'Verified Program' },
  { label: 'Social Procurement', sub: 'Indigenous Partnerships' },
  { label: 'Modern Slavery',     sub: 'Act Compliant' },
]
---

<div class="bg-navy border-t border-white/10 border-b border-white/10">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6">
    <ul class="flex flex-wrap" role="list">
      {items.map(item => (
        <li class="flex items-center gap-2.5 px-4 py-8 sm:py-12 border-r border-white/10 last:border-r-0">
          <div class="flex-shrink-0 w-5 h-5 rounded-full border border-teal/40 bg-teal/10 flex items-center justify-center">
            <svg class="w-2.5 h-2.5 text-teal" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-200 leading-none">{item.label}</p>
            <p class="text-xs text-white/35 mt-0.5">{item.sub}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</div>
