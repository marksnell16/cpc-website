---
interface Stat {
  value: string
  label: string
}

interface Props {
  stats: Stat[]
  color?: string
}

const { stats, color = '#14b8a6' } = Astro.props
---

<div class="stat-callout" role="list" aria-label="Key statistics">
  {stats.map(s => (
    <div class="stat-callout-cell" role="listitem">
      <span class="stat-callout-value" style={`color: ${color}`}>{s.value}</span>
      <span class="stat-callout-label">{s.label}</span>
    </div>
  ))}
</div>

<style>
  .stat-callout {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 1px;
    background: #e2e8f0;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    overflow: hidden;
    margin: 3rem 0;
  }

  .stat-callout-cell {
    background: #f8fafc;
    padding: 1.5rem 1.25rem;
    text-align: center;
  }

  .stat-callout-value {
    font-family: var(--font-display);
    font-size: 2.25rem;
    font-weight: 800;
    line-height: 1;
    display: block;
  }

  .stat-callout-label {
    font-size: 0.75rem;
    color: #64748b;
    margin-top: 0.375rem;
    line-height: 1.4;
    display: block;
  }
</style>
