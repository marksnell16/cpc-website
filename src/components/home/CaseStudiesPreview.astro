---
const cases = [
  {
    code: 'CS-01',
    client: 'Queensland Government',
    sector: 'Government & Defence',
    location: 'Queensland · Statewide',
    headline: '400+ government buildings, one ISO-compliant cleaning program',
    metrics: [
      { value: '400+', label: 'Buildings serviced' },
      { value: '100%', label: 'Audit compliance' },
      { value: '5yr',  label: 'Contract term' },
    ],
    href: '/case-studies/',
  },
  {
    code: 'CS-02',
    client: 'Coal-Fired Power Station',
    sector: 'Industrial & Power Station',
    location: 'Queensland · Industrial',
    headline: 'Permit-to-work cleaning compliance in live coal-fired generation',
    metrics: [
      { value: 'Zero', label: 'Lost-time injuries' },
      { value: 'ISO 45001', label: 'OHS compliance' },
      { value: '24/7', label: 'Operational coverage' },
    ],
    href: '/case-studies/',
  },
  {
    code: 'CS-03',
    client: 'TAFE Queensland',
    sector: 'Education & TAFE',
    location: 'Queensland · 50+ campuses',
    headline: 'Consistent cleaning standards across a distributed campus network',
    metrics: [
      { value: '50+', label: 'Campus locations' },
      { value: '98%', label: 'Service satisfaction' },
      { value: '3yr', label: 'Contract extended' },
    ],
    href: '/case-studies/',
  },
]
---

<section class="bg-[#0a0f1a] py-20 lg:py-28 border-t border-white/5" aria-label="Case studies">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6">

    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
      <div>
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-3">Proven in the Field</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight">Case Studies</h2>
      </div>
      <a href="/case-studies/" class="text-sm font-semibold text-teal hover:text-teal-bright transition-colors flex-shrink-0">
        All case studies →
      </a>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {cases.map(c => (
        <a
          href={c.href}
          class="group block bg-white rounded-xl overflow-hidden transition-all duration-200 hover:-translate-y-0.5 hover:shadow-xl"
        >
          <!-- Teal top stripe + sector tag -->
          <div class="px-6 pt-5 pb-4 border-b border-slate-100 border-t-4 border-t-teal">
            <span class="inline-flex items-center text-xs font-bold tracking-wider px-2.5 py-1 rounded-full bg-teal/10 text-teal">
              {c.sector}
            </span>
          </div>

          <div class="p-6">
            <p class="text-xs text-slate-400 mb-3">{c.location}</p>
            <h3 class="text-base font-semibold text-navy leading-snug mb-5 group-hover:text-teal transition-colors">
              {c.headline}
            </h3>

            <!-- Outcome metrics -->
            <dl class="grid grid-cols-3 gap-3 mb-5">
              {c.metrics.map(m => (
                <div>
                  <dt class="text-xl font-bold text-teal leading-none">{m.value}</dt>
                  <dd class="text-xs text-slate-400 mt-1 leading-tight">{m.label}</dd>
                </div>
              ))}
            </dl>

            <span class="text-sm text-teal font-semibold group-hover:text-teal-bright transition-colors">
              Read case study →
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
