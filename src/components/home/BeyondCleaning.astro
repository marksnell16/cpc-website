---
const capabilities = [
  {
    title: 'AI-Driven Client Portal',
    body: 'Real-time cleaning status, audit scores, compliance tracking and incident reporting. Accessible 24/7 by facilities managers, asset managers and procurement teams across every site.',
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0H3"/></svg>`,
  },
  {
    title: 'Waste & ESG Reporting',
    body: 'Site-level waste volumes, diversion rates and contamination insights. Monthly ESG dashboards that turn waste into a measurable, reportable KPI. Not an afterthought.',
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/></svg>`,
  },
  {
    title: 'Carbon Intelligence',
    body: 'Carbon footprint tracked per site. Carbon Neutral Cleaning Certificates issued with verified offsets. Documented, auditable sustainability outcomes that support Net Zero reporting.',
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/></svg>`,
  },
  {
    title: 'Portfolio Benchmarking',
    body: 'Cross-site performance comparison, efficiency opportunities and strategic insights. Data that lets procurement teams demonstrate innovation and leadership, not just cost management.',
    icon: `<svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>`,
  },
]
---

<section class="bg-[#0a0f1a] py-20 lg:py-28 border-t border-white/5" aria-label="Beyond Cleaning">
  <div class="max-w-screen-xl mx-auto px-4 sm:px-6">

    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-start">

      <!-- Left: statement -->
      <div class="lg:sticky lg:top-24">
        <p class="text-xs font-bold tracking-widest uppercase text-teal mb-4">Beyond Cleaning</p>
        <h2 class="text-3xl md:text-4xl font-bold text-white leading-tight mb-6">
          Most providers clean buildings.<br />
          CPC helps you run<br class="hidden sm:block" /> smarter assets.
        </h2>
        <p class="text-slate-400 leading-relaxed mb-6">
          CPC's technology platform delivers compliance visibility, ESG intelligence and carbon reporting to every level of your organisation: from the facilities manager on the ground to the board reporting to investors.
        </p>
        <p class="text-slate-500 text-sm leading-relaxed mb-8 border-l-2 border-teal/30 pl-4">
          Most cleaning companies only solve for the Facilities Manager.<br />
          CPC solves for the entire organisation.
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/client-portal/"
            class="inline-flex items-center px-5 py-2.5 bg-teal text-navy font-semibold text-sm rounded hover:bg-teal-bright transition-colors"
          >
            See the Client Portal →
          </a>
          <a
            href="/authority/cleaning-technology-robotics/"
            class="inline-flex items-center px-5 py-2.5 border border-white/15 text-white font-semibold text-sm rounded hover:border-teal/40 hover:text-teal transition-colors"
          >
            Technology overview
          </a>
        </div>
      </div>

      <!-- Right: capability tiles -->
      <div class="grid sm:grid-cols-2 gap-4">
        {capabilities.map(c => (
          <div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/8 hover:border-teal/20 transition-all duration-200">
            <div class="text-teal mb-3" set:html={c.icon} />
            <h3 class="text-sm font-bold text-white mb-2">{c.title}</h3>
            <p class="text-xs text-slate-400 leading-relaxed">{c.body}</p>
          </div>
        ))}
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/8 grid sm:grid-cols-3 gap-6 text-center">
      {[
        { stat: 'Real-time', label: 'Compliance visibility across every site' },
        { stat: 'Monthly', label: 'ESG and waste dashboards per asset' },
        { stat: 'Board-ready', label: 'Carbon data and sustainability certificates' },
      ].map(s => (
        <div>
          <p class="text-lg font-black text-teal mb-1">{s.stat}</p>
          <p class="text-xs text-slate-400">{s.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
